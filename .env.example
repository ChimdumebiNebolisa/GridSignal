# GridSignal Texas - Environment Variables
# Copy this file to .env.local and fill in your API keys.
# Never commit .env.local to source control.

# Required: NREL Developer API Key (https://developer.nrel.gov/signup/)
NREL_API_KEY=

# Required: EIA API Key (https://www.eia.gov/opendata/register.php)
EIA_API_KEY=

# Optional: Census API Key (only needed for live Census calls; static cache is used by default)
CENSUS_API_KEY=

# Optional: ERCOT credentials (EIA ERCO is the default grid strain source)
ERCOT_API_KEY=
ERCOT_USERNAME=
ERCOT_PASSWORD=
ERCOT_SUBSCRIPTION_KEY=

# App name
NEXT_PUBLIC_APP_NAME=GridSignal Texas
